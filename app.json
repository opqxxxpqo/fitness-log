{
  "expo": {
    "name": "健身记录",
    "slug": "fitness-log-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fitnesslog",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F0EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opqxxx.fitnesslog"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F2F0EC"
      },
      "package": "com.opqxxx.fitnesslog",
      "versionCode": 4
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    }
  }
}
