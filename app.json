      "package": "com.codex.fitnesslog",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon2-adaptive.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "允许健身记录访问你的照片，用于给训练项目设置图片。"
        }
      ]
    ],
    "owner": "opqxxx"
