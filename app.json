{
  "expo": {
    "name": "健身记录",
    "slug": "fitness-log",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon2.png",
    "extra": {
      "eas": {
        "projectId": "4641858b-2700-4bfe-87cc-6b95d5dbcc21"
      }
    },
    "ios": {
      "supportsTablet": false,
